DJANGO_SECRET_KEY=replace-with-a-secure-secret
DJANGO_DEBUG=false   # set to true only for local development
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Razorpay Payment Gateway Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Email / SMTP Configuration ────────────────────────────────────────────────
# Transactional email provider credentials (SendGrid, Mailgun, Resend, AWS SES).
# In DEBUG mode without EMAIL_HOST set, Django falls back to console.EmailBackend
# which prints emails to stdout — useful for local development.
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your_sendgrid_api_key
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=Udaan Studio <hello@udaanstudio.com>
EMAIL_TIMEOUT=10
FRONTEND_URL=https://udaanstudio.com

# ── Google OAuth2 (Google Sign-In) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=576569277083-rkco6ojbej4m1r2mmjtvn71rlq2oph54.apps.googleusercontent.com

# ── WhatsApp Notification Service ───────────────────────────────────────────
WHATSAPP_PROVIDER=console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

